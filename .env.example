OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=nano-banana-pro
CONVEX_URL=
CONVEX_ADMIN_KEY=
# Secret for signing the single-use OAuth/Apple session-mint token (HMAC-SHA256).
# Used by api/oauth/callback.ts (mint) and api/auth.ts action:"oauth" (verify).
# Set to a long random string, e.g. `openssl rand -hex 32`.
AUTH_TOKEN_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# RevenueCat: shared secret the webhook expects in the Authorization header
# (set the exact same value as the "Authorization" header in the RevenueCat
# dashboard webhook config). See api/revenuecat-webhook.ts.
REVENUECAT_WEBHOOK_SECRET=
# RevenueCat public iOS (App Store) SDK key, exposed to the native client build.
VITE_REVENUECAT_IOS_KEY=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# --- WEB Apple OAuth (redirect flow via api/oauth/start + callback) ---
# OAUTH_APPLE_CLIENT_ID here is your Apple SERVICES ID (e.g. com.songghost.web),
# NOT the app bundle id. Web Sign in with Apple is out of the iOS v1 scope but
# these keep the existing web redirect flow working.
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=
# --- NATIVE Sign in with Apple (api/auth-apple.ts identity-token verify) ---
# The `aud` claim Apple stamps into identity tokens minted for the iOS app is the
# app BUNDLE ID. api/auth-apple.ts verifies the token's aud against this. Defaults
# to com.songghost.app if unset.
APPLE_BUNDLE_ID=com.songghost.app
# NOTE: if/when web Sign in with Apple is added, its identity tokens carry the
# Services ID as `aud` instead — verify those against APPLE_SERVICES_ID, not the
# bundle id. Not used by the native flow; documented here for completeness.
# APPLE_SERVICES_ID=com.songghost.web
